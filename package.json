    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "retry": "0.12.0",
    "signal-exit": "3.0.7",
    "socks-proxy-agent": "10.0.0",
    "source-map-support": "0.5.21",
    "ssim.js": "^3.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
