{
  "name": "playwright-internal",
  "private": true,
  "version": "1.61.0-next",
  "description": "A high-level API to automate web browsers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microsoft/playwright.git"
  },
  "homepage": "https://playwright.dev",
  "engines": {
    "node": ">=24"
  },
  "author": {
    "name": "Microsoft Corporation"
  },
  "license": "Apache-2.0",
  "scripts": {
    "ctest": "node --trace-deprecation ./node_modules/playwright/cli.js test --config=tests/library/playwright.config.ts --project=chromium-*",
    "ftest": "./node_modules/playwright/cli.js test --config=tests/library/playwright.config.ts --project=firefox-*",
    "wtest": "./node_modules/playwright/cli.js test --config=tests/library/playwright.config.ts --project=webkit-*",
    "wvtest": "./node_modules/playwright/cli.js test --config=tests/webview/playwright.config.ts",
    "atest": "./node_modules/playwright/cli.js test --config=tests/android/playwright.config.ts",
    "etest": "./node_modules/playwright/cli.js test --config=tests/electron/playwright.config.ts",
    "itest": "./node_modules/playwright/cli.js test --config=tests/installation/playwright.config.ts",
    "stest": "./node_modules/playwright/cli.js test --config=tests/stress/playwright.config.ts",
    "biditest": "./node_modules/playwright/cli.js test --config=tests/bidi/playwright.config.ts",
    "ttest": "./node_modules/playwright/cli.js test --config=tests/playwright-test/playwright.config.ts",
    "ttest:bun": "bun ./node_modules/playwright/cli.js test --config=tests/playwright-test/playwright.config.ts",
    "ctest:bun": "bun ./node_modules/playwright/cli.js test --config=tests/library/playwright.config.ts --project=chromium-*",
    "ct": "./node_modules/playwright/cli.js test tests/components/test-all.spec.js --reporter=list",
    "test": "./node_modules/playwright/cli.js test --config=tests/library/playwright.config.ts",
    "test-mcp": "./node_modules/playwright/cli.js test --config=tests/mcp/playwright.config.ts",
    "ctest-mcp": "./node_modules/playwright/cli.js test --config=tests/mcp/playwright.config.ts --project=chrome",
    "test-extension": "./node_modules/playwright/cli.js test --config=tests/extension/playwright.config.ts",
    "oxlint": "oxlint",
    "tsc": "tsgo -p tsconfig.check.json",
    "doc": "node utils/doclint/cli.js",
    "lint": "npm run oxlint && npm run tsc && npm run doc && npm run check-deps && node utils/generate_channels.js && node utils/generate_types/ && npm run lint-tests && npm run test-types && npm run lint-packages",
    "lint-packages": "node utils/workspace.js --ensure-consistent",
    "lint-tests": "node utils/lint_tests.js",
    "flint": "concurrently \"npm run oxlint\" \"npm run tsc\" \"npm run doc\" \"npm run check-deps\" \"node utils/generate_channels.js\" \"npm run lint-tests\" \"npm run test-types\" \"npm run lint-packages\" \"node utils/doclint/linting-code-snippets/cli.js --js-only\"",
    "clean": "node utils/build/clean.js",
    "build": "node utils/build/build.js",
    "watch": "node utils/build/build.js --watch --lint",
    "test-types": "node utils/generate_types/ && concurrently \"tsgo -p utils/generate_types/test/tsconfig.json\" \"tsgo -p ./tests/\"",
    "roll": "node utils/roll_browser.js",
    "sync-upstream": "bash utils/sync_upstream.sh",
    "check-deps": "node utils/check_deps.js",
    "build-android-driver": "./utils/build_android_driver.sh",
    "innerloop": "playwright run-server --reuse-browser",
    "test-playwright-cli": "./node_modules/playwright/cli.js test --config=tests/mcp/playwright.config.ts --project=chrome cli-",
    "playwright-cli": "node packages/playwright-core/lib/tools/cli-client/cli.js",
    "playwright-cli-readme": "node utils/generate_cli_help.js --readme"
  },
  "workspaces": [
    "packages/*"
  ],
