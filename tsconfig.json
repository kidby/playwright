{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      /*
        @-prefixed paths are for importing types and are safe for all runtimes
        (they don't collide with npm package names).

        DO NOT add "playwright-core/lib/*" or "playwright/lib/*" paths here.
        Bun follows tsconfig paths at runtime, which redirects compiled JS
        bundles to TypeScript sources and causes ~27× slowdown.
        Those paths live in tsconfig.check.json (used for tsc --noEmit only).
      */
      "@dashboard/*": ["./packages/dashboard/src/*"],
      "@trace-viewer/*": ["./packages/trace-viewer/src/*"],
      "@html-reporter/*": ["./packages/html-reporter/src/*"],
      "@injected/*": ["./packages/injected/src/*"],
      "@isomorphic/*": ["./packages/isomorphic/*"],
      "@utils/*": ["./packages/utils/*"],
      "@protocol/*": ["./packages/protocol/src/*"],
      "@recorder/*": ["./packages/recorder/src/*"],
      "@testIsomorphic/*": ["./packages/playwright/src/isomorphic/*"],
      "@trace/*": ["./packages/trace/src/*"],
      "@web/*": ["./packages/web/src/*"],
      "@playwright/*": ["./packages/playwright/src/*"],
    },
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "allowJs": false,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": false,
    "useDefineForClassFields": false,
    "skipLibCheck": true,
  },
  "compileOnSave": true,
  "include": ["packages"],
  "exclude": [
    "packages/*/lib",
    "packages/extension",
  ]
}
